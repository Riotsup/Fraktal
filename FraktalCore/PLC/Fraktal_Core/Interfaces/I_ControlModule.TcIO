  <Itf Name="I_ControlModule" Id="{1944b7ae-7f75-45d0-adb9-181c389f8c43}">
    <Declaration><![CDATA[// Core §3.2 — HAL-bound leaf tier. Same generic command vocabulary as I_EquipmentModule.
