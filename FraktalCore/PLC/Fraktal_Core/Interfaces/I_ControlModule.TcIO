    <Method Name="ExecuteCommand" Id="{4eda4239-3160-4b3f-8130-a321f054962a}">
      <Declaration><![CDATA[METHOD ExecuteCommand : BOOL
VAR_INPUT
    Command : DINT;   // value of the type's E_<Type>Command
END_VAR]]></Declaration>
    </Method>
    <Method Name="AbortCommand" Id="{d9340362-f5ae-4129-b7b8-eaced7c637cd}">
      <Declaration><![CDATA[METHOD AbortCommand : BOOL]]></Declaration>
    </Method>
  </Itf>
