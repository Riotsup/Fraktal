    <DefaultNamespace>Fraktal_Press_Demo</DefaultNamespace>
    <Company>fraktal-automation</Company><Title>Fraktal_Press_Demo</Title>
    <ProjectVersion>0.1.0.7</ProjectVersion><Released>false</Released>
    <Author>fraktal-automation</Author>
    <Description>CX2030 virtual/physical commissioning example: XTI-linked EK1200/EL1809/EL2809 HAL mapping, two-hand start, interlocked door/part slide, safety aliases, Control On/Off, AUTO/HOME/MANUAL, and model recipes.</Description>
  </PropertyGroup>
  <ItemGroup>
    <!-- Core §4.2: folders follow the instance tree. 00_System = composition root,
         raw I/O + safety aliases, hardware driver, domain coordinator, withdrawal
         layer, and the sim plant. 01_PneumaticPress = the root Unit's application
         engineering data, grouped by owner-local role (Sequences, Release,
         Recipes, and Io). -->
    <Compile Include="PlcTask.TcTTO"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Sequences\FB_PressDemoLoadPosition.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Sequences\FB_PressDemoHome.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Sequences\FB_PressDemoChangeover.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Sequences\FB_PressDemoAuto.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Release\FB_PressDemoRelease.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\FB_PressDemoUnit.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="00_System\MAIN.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="00_System\GVL_PressIO.TcGVL"><SubType>Code</SubType></Compile>
    <Compile Include="00_System\GVL_PressSafety.TcGVL"><SubType>Code</SubType></Compile>
    <Compile Include="00_System\FB_PressIoDriver.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="00_System\FB_PressControlDomain.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="00_System\FB_PressOutputAuthority.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="00_System\FB_PressSimulationDriver.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Recipes\FB_PressRecipeCatalog.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Io\FB_PressIoCatalog.TcPOU"><SubType>Code</SubType></Compile>
    <Compile Include="01_PneumaticPress\Io\GVL_PressFieldbus.TcGVL"><SubType>Code</SubType></Compile>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="00_System" />
    <Folder Include="00_System\Hardware" />
    <Folder Include="01_PneumaticPress" />
