  <POU Name="PRG_TcUnitRunner" Id="{86af2602-fbcc-443b-aee7-03f4e3f99992}" SpecialFunc="None">
    <Declaration><![CDATA[// Core §5.7 / TC3 §5.7 — one open-ended gate: every suite joins unchanged (§6.8, H.6)
