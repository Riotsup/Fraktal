    ConfigurableCylinderTests : FB_ConfigurableCylinderCM_Tests;
    ClampTests     : FB_ClampEM_Tests;
    ClampStationTests : FB_ClampStationUnit_Tests;
    HmiTests       : FB_Hmi_Tests;
    IoTopologyTests: FB_IoTopologyPublisher_Tests;
    InputModuleTests: FB_InputCM_Tests;
    AccessTests    : FB_Access_Tests;
    AlarmLogTests  : FB_AlarmLog_Tests;
    ManualCmdTests : FB_ManualCmd_Tests;
    MultiRootTests : FB_MultiRoot_Tests;
    OeeTests       : FB_Oee_Tests;
    ReleaseTests   : FB_Release_Tests;
    ShelveTests    : FB_Shelve_Tests;
    TcpDeviceTests : FB_TcpDev_Tests;
    PartTraceTests : FB_PartTrace_Tests;
