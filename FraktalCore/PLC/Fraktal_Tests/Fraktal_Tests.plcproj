    <Title>Fraktal_Tests</Title>
    <ProjectVersion>0.1.0.7</ProjectVersion>
    <Released>false</Released>
    <Author>fraktal-automation</Author>
    <Description>Aggregate Fraktal Core + Modules + Press Demo TcUnit gate - excluded from deployed runtime (Core 5.7).</Description>
  </PropertyGroup>
  <ItemGroup>
    <!-- This manifest deliberately lives at the PLC common ancestor. TwinCAT's
         Add Existing Item importer rejects a raw Compile path containing '..'
         before it evaluates Link metadata. All sources therefore use downward,
         repository-relative paths while remaining single-source linked files. -->
    <Compile Include="Fraktal_Tests\PlcTask.TcTTO">
      <Link>PlcTask.TcTTO</Link><SubType>Code</SubType>
    </Compile>
    <!-- Project sources are linked, never copied: the aggregate gate tests the
         same application Unit, release logic, and native SFCs that are deployed. -->
    <Compile Include="Fraktal_Press_Demo\01_PneumaticPress\Sequences\FB_PressDemoLoadPosition.TcPOU">
      <Link>PressDemo\Sequences\FB_PressDemoLoadPosition.TcPOU</Link><SubType>Code</SubType>
    </Compile>
